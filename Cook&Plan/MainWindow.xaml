<Window x:Class="Cook_Plan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cook&amp;Plan" Height="680" Width="1050"
        Name="RootWindow">
    <Window.Resources>

        <!-- Стиль ComboBox — фиксирует цвет выпадающего списка -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Focusable="False"
                                IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"/>
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M0,0 L4,4 L8,0 Z"
                                                      Fill="{Binding Foreground,
                                                             RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter Name="ContentSite"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="8,4,24,4"
                                VerticalAlignment="Center"/>

                            <Popup Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown" MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="200">
                                    <Border Name="DropDownBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="4">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль ComboBoxItem -->
        <Style x:Key="ThemedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- Шапка -->
        <Border DockPanel.Dock="Top" Padding="16,10" Name="HeaderPanel">
            <DockPanel>
                <TextBlock Text="🍳 Cook&amp;Plan" FontSize="22" FontWeight="Bold"
                           Name="HeaderTitle" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="LightBtn" Content="☀️" Width="38" Height="38"
                            Margin="4,0" Click="LightBtn_Click" FontSize="16"/>
                    <Button Name="DarkBtn" Content="🌙" Width="38" Height="38"
                            Margin="4,0" Click="DarkBtn_Click" FontSize="16"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Name="MainTabs" Padding="0">

            <!-- ══ Вкладка 1: Рецепты ══════════════════════════════════ -->
            <TabItem Header="📋 Рецепты">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12" Name="LeftPanel">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="➕ Создать рецепт (Builder)"
                                           FontSize="14" FontWeight="Bold"
                                           Margin="0,0,0,10" Name="BuilderLabel"/>

                                <TextBlock Text="Название:" Margin="0,6,0,2" FontWeight="SemiBold" Name="LblName"/>
                                <TextBox Name="TxtName" Padding="6,4"/>

                                <TextBlock Text="Описание:" Margin="0,6,0,2" FontWeight="SemiBold" Name="LblDesc"/>
                                <TextBox Name="TxtDesc" Padding="6,4" Height="55"
                                         TextWrapping="Wrap" AcceptsReturn="True"/>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="Время (мин):" Margin="0,0,0,2"
                                                   FontWeight="SemiBold" Name="LblTime"/>
                                        <TextBox Name="TxtTime" Padding="6,4" Text="30"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="Порции:" Margin="0,0,0,2"
                                                   FontWeight="SemiBold" Name="LblServings"/>
                                        <TextBox Name="TxtServings" Padding="6,4" Text="2"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Ингредиенты:" Margin="0,10,0,2"
                                           FontWeight="SemiBold" Name="LblIngr"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="TxtIngrName" Grid.Column="0"
                                             Padding="6,4" Margin="0,0,4,0" ToolTip="Название продукта"/>
                                    <TextBox Name="TxtIngrAmount" Grid.Column="1"
                                             Padding="6,4" Margin="0,0,4,0" Text="100"/>
                                    <Button Grid.Column="2" Content="+" FontSize="16"
                                            Name="BtnAddIngr" Click="BtnAddIngr_Click"/>
                                </Grid>
                                <ListBox Name="IngrList" Height="75" Margin="0,0,0,6"/>

                                <TextBlock Text="Шаги приготовления:" Margin="0,6,0,2"
                                           FontWeight="SemiBold" Name="LblSteps"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="TxtStep" Grid.Column="0"
                                             Padding="6,4" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="+" FontSize="16"
                                            Name="BtnAddStep" Click="BtnAddStep_Click"/>
                                </Grid>
                                <ListBox Name="StepList" Height="75" Margin="0,0,0,10"/>

                                <Button Name="BtnCreate" Content="🔨 Создать рец��пт"
                                        Padding="10,7" Click="BtnCreate_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Padding="12" Name="RightPanel">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="📄 Рецепты (Prototype — клонирование)"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,8" Name="PrototypeLabel"/>

                            <Button DockPanel.Dock="Bottom" Name="BtnClone"
                                    Content="🔁 Клонировать и изменить название"
                                    Padding="10,7" Click="BtnClone_Click"
                                    IsEnabled="False" Margin="0,8,0,0"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <ListBox Grid.Row="0" Name="RecipeList" Margin="0,0,0,8"
                                         SelectionChanged="RecipeList_SelectionChanged"/>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Name="RecipeDetails" Visibility="Collapsed">
                                        <TextBlock Name="DetailName" FontSize="15"
                                                   FontWeight="Bold" Margin="0,4,0,2"/>
                                        <TextBlock Name="DetailInfo" Margin="0,0,0,8" Opacity="0.7"/>
                                        <TextBlock Text="Ингредиенты:" FontWeight="Bold"
                                                   Margin="0,0,0,4" Name="LblDetailIngr"/>
                                        <ListBox Name="DetailIngredients" BorderThickness="0"
                                                 Margin="0,0,0,8" MaxHeight="120"/>
                                        <TextBlock Text="Шаги:" FontWeight="Bold"
                                                   Margin="0,0,0,4" Name="LblDetailSteps"/>
                                        <ListBox Name="DetailSteps" BorderThickness="0" MaxHeight="120"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ Вкладка 2: План питания ════════════════════════════ -->
            <TabItem Header="📅 План питания">
                <Border Padding="16" Name="MealPlanPanel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="📅 План питания на неделю"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,10" Name="MealPlanLabel"/>

                            <TextBlock Text="День недели:" Margin="0,0,0,4" Name="LblDay"/>
                            <ComboBox Name="CmbDay" Style="{StaticResource ThemedComboBox}">
                                <ComboBoxItem Content="Понедельник" IsSelected="True"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Вторник"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Среда"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Четверг"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Пятница"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Суббота"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Воскресенье"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                            </ComboBox>

                            <TextBlock Text="Тип питания:" Margin="0,0,0,4" Name="LblMealType"/>
                            <ComboBox Name="CmbMealType" Style="{StaticResource ThemedComboBox}">
                                <ComboBoxItem Content="Завтрак" IsSelected="True"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Обед"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Ужин"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                                <ComboBoxItem Content="Перекус"
                                              Style="{StaticResource ThemedComboBoxItem}"/>
                            </ComboBox>

                            <TextBlock Text="Рецепт:" Margin="0,0,0,4" Name="LblMealRecipe"/>
                            <ComboBox Name="CmbMealRecipe" Style="{StaticResource ThemedComboBox}"/>

                            <Button Name="BtnAddMeal" Content="➕ Добавить в план"
                                    Padding="10,7" Click="BtnAddMeal_Click" Margin="0,0,0,12"/>

                            <TextBlock Text="Записи плана:" FontWeight="Bold"
                                       Margin="0,0,0,4" Name="LblPlanEntries"/>
                            <ListBox Name="MealPlanList" Height="220"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="🛒 Список покупок из плана (MealPlanShoppingListFactory)"
                                       FontSize="13" FontWeight="Bold"
                                       Margin="0,0,0,10" Name="MealPlanFactoryLabel"
                                       TextWrapping="Wrap"/>
                            <Button Name="BtnCreateMealPlanList"
                                    Content="🏭 Создать список покупок из плана"
                                    Padding="10,7" Click="BtnCreateMealPlanList_Click"
                                    Margin="0,0,0,10"/>
                            <TextBlock Text="Результат:" FontWeight="Bold"
                                       Margin="0,0,0,4" Name="LblMealPlanResult"/>
                            <ListBox Name="MealPlanShoppingList" Height="320"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ══ Вкладка 3: Список покупок ══════════════════════════ -->
            <TabItem Header="🛒 Список покупок">
                <Border Padding="16" Name="ShoppingPanel">
                    <StackPanel>
                        <TextBlock Text="🏭 Factory Method — SingleRecipeShoppingListFactory"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                   Name="FactoryLabel"/>
                        <TextBlock Text="Выберите рецепт:" Margin="0,0,0,4" Name="LblSelectRecipe"/>
                        <ComboBox Name="CmbRecipes" Style="{StaticResource ThemedComboBox}"/>
                        <Button Name="BtnCreateList" Content="🛒 Создать список покупок"
                                Padding="10,7" Click="BtnCreateList_Click" Margin="0,0,0,12"
                                HorizontalAlignment="Left" Width="240"/>
                        <TextBlock Text="Результат:" FontWeight="Bold"
                                   Margin="0,0,0,6" Name="LblResult"/>
                        <ListBox Name="ShoppingListBox" Height="350"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ══ Вкладка 4: Кэш ══════════════════════════════════════ -->
            <TabItem Header="💾 Кэш">
                <Border Padding="16" Name="CachePanel">
                    <StackPanel>
                        <TextBlock Text="🔒 Singleton — RecipeCache"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                                   Name="SingletonLabel"/>

                        <Border Name="CacheInfoBox" Padding="10" Margin="0,0,0,12"
                                CornerRadius="4" BorderThickness="1">
                            <TextBlock Name="CacheInstanceInfo"
                                       FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="ℹ️ Рецепты загружаются в кэш автоматически при открытии."
                                   Margin="0,0,0,6" FontStyle="Italic"
                                   Name="LblCacheInfo" TextWrapping="Wrap"/>

                        <!-- Выбор рецепта для операций с кэшем -->
                        <TextBlock Text="Выберите рецепт для проверки/удаления:"
                                   Margin="0,0,0,4" Name="LblCacheSelect"/>
                        <ComboBox Name="CmbCacheRecipe"
                                  Style="{StaticResource ThemedComboBox}"/>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Name="BtnCheckCache"
                                    Content="🔍 Проверить в кэше"
                                    Padding="10,7" Click="BtnCheckCache_Click" Margin="0,0,8,4"/>
                            <Button Name="BtnClearCache"
                                    Content="🗑️ Удалить из кэша"
                                    Padding="10,7" Click="BtnClearCache_Click" Margin="0,0,8,4"/>
                            <Button Name="BtnReloadCache"
                                    Content="🔄 Перезагрузить все"
                                    Padding="10,7" Click="BtnReloadCache_Click" Margin="0,0,0,4"/>
                        </WrapPanel>

                        <TextBlock Text="Лог операций:" FontWeight="Bold"
                                   Margin="0,0,0,6" Name="LblLog"/>
                        <ListBox Name="CacheLog" Height="270"/>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>