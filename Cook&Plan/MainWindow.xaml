<Window x:Class="Cook_Plan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cook&amp;Plan"
        Height="760"
        Width="1180"
        MinHeight="700"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Name="RootWindow">

    <Window.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,8,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SoftList" TargetType="ListBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Padding="20,14" Name="HeaderPanel">
            <DockPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="🍳 Cook&amp;Plan"
                               Name="HeaderTitle"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="Планирование рецептов, питания и списка покупок"
                               Name="HeaderSubtitle"
                               FontSize="13"
                               Opacity="0.75"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="LightBtn"
                            Content="☀️ Светлая"
                            Style="{StaticResource MainButton}"
                            Click="LightBtn_Click"/>
                    <Button Name="DarkBtn"
                            Content="🌙 Тёмная"
                            Style="{StaticResource MainButton}"
                            Click="DarkBtn_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN -->
        <TabControl Name="MainTabs" Padding="0">

            <!-- RECIPES -->
            <TabItem Header="📋 Рецепты">
                <Grid Name="RecipesPanel" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CREATE RECIPE -->
                    <Border Grid.Column="0" Name="CreateRecipeCard" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Новый рецепт"
                                           Name="LblCreateRecipe"
                                           Style="{StaticResource TitleText}"/>

                                <TextBlock Text="Название" Name="LblName" Style="{StaticResource SectionText}"/>
                                <TextBox Name="TxtName" Style="{StaticResource InputTextBox}"/>

                                <TextBlock Text="Описание" Name="LblDesc" Style="{StaticResource SectionText}"/>
                                <TextBox Name="TxtDesc"
                                         Style="{StaticResource InputTextBox}"
                                         Height="70"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="Тип питания" Name="LblRecipeMealType" Style="{StaticResource SectionText}"/>
                                        <ComboBox Name="CmbRecipeMealType" Style="{StaticResource InputComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="Кухня" Name="LblRecipeCuisine" Style="{StaticResource SectionText}"/>
                                        <ComboBox Name="CmbRecipeCuisine" Style="{StaticResource InputComboBox}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="Сложность" Name="LblRecipeDifficulty" Style="{StaticResource SectionText}"/>
                                        <ComboBox Name="CmbRecipeDifficulty" Style="{StaticResource InputComboBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                        <TextBlock Text="Минуты" Name="LblTime" Style="{StaticResource SectionText}"/>
                                        <TextBox Name="TxtTime" Text="30" Style="{StaticResource InputTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                        <TextBlock Text="Порции" Name="LblServings" Style="{StaticResource SectionText}"/>
                                        <TextBox Name="TxtServings" Text="2" Style="{StaticResource InputTextBox}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Ингредиенты" Name="LblIngredients" Style="{StaticResource SectionText}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Name="TxtIngrName"
                                             Grid.Column="0"
                                             Style="{StaticResource InputTextBox}"
                                             Margin="0,0,6,0"
                                             ToolTip="Название ингредиента"/>

                                    <TextBox Name="TxtIngrAmount"
                                             Grid.Column="1"
                                             Text="100"
                                             Style="{StaticResource InputTextBox}"
                                             Margin="0,0,6,0"/>

                                    <TextBox Name="TxtIngrUnit"
                                             Grid.Column="2"
                                             Text="г"
                                             Style="{StaticResource InputTextBox}"
                                             Margin="0,0,6,0"/>

                                    <Button Name="BtnAddIngr"
                                            Grid.Column="3"
                                            Content="+"
                                            Style="{StaticResource MainButton}"
                                            Margin="0"
                                            Click="BtnAddIngr_Click"/>
                                </Grid>

                                <ListBox Name="IngrList"
                                         Height="95"
                                         Style="{StaticResource SoftList}"/>

                                <TextBlock Text="Шаги приготовления" Name="LblSteps" Style="{StaticResource SectionText}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Name="TxtStep"
                                             Grid.Column="0"
                                             Style="{StaticResource InputTextBox}"
                                             Margin="0,0,6,0"/>

                                    <Button Name="BtnAddStep"
                                            Grid.Column="1"
                                            Content="+"
                                            Style="{StaticResource MainButton}"
                                            Margin="0"
                                            Click="BtnAddStep_Click"/>
                                </Grid>

                                <ListBox Name="StepList"
                                         Height="95"
                                         Style="{StaticResource SoftList}"/>

                                <Button Name="BtnCreate"
                                        Content="Сохранить рецепт"
                                        Style="{StaticResource MainButton}"
                                        Click="BtnCreate_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- RECIPE LIST -->
                    <Border Grid.Column="1" Name="RecipeListCard" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Мои рецепты"
                                       Name="LblRecipeList"
                                       Style="{StaticResource TitleText}"/>

                            <ListBox Grid.Row="1"
                                     Name="RecipeList"
                                     Style="{StaticResource SoftList}"
                                     SelectionChanged="RecipeList_SelectionChanged"/>

                            <Border Grid.Row="2" Name="RecipeDetailsCard" Style="{StaticResource Card}" Margin="0,12,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Name="RecipeDetails" Visibility="Collapsed">
                                        <TextBlock Name="DetailName"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Name="DetailInfo"
                                                   FontSize="13"
                                                   Opacity="0.75"
                                                   Margin="0,0,0,12"/>
                                        <TextBlock Name="DetailDescription"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="Ингредиенты"
                                                   Name="LblDetailIngredients"
                                                   Style="{StaticResource SectionText}"/>
                                        <ListBox Name="DetailIngredients"
                                                 Style="{StaticResource SoftList}"
                                                 Height="115"/>

                                        <TextBlock Text="Приготовление"
                                                   Name="LblDetailSteps"
                                                   Style="{StaticResource SectionText}"/>
                                        <ListBox Name="DetailSteps"
                                                 Style="{StaticResource SoftList}"
                                                 Height="135"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                                <Button Name="BtnClone"
                                        Content="Создать копию"
                                        Style="{StaticResource MainButton}"
                                        IsEnabled="False"
                                        Click="BtnClone_Click"/>

                                <Button Name="BtnDeleteRecipe"
                                        Content="Удалить рецепт"
                                        Style="{StaticResource MainButton}"
                                        IsEnabled="False"
                                        Click="BtnDeleteRecipe_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- MEAL PLAN -->
            <TabItem Header="📅 План питания">
                <Grid Name="MealPlanPanel" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Name="MealPlanFormCard" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Добавить приём пищи"
                                       Name="LblMealPlanTitle"
                                       Style="{StaticResource TitleText}"/>

                            <TextBlock Text="День недели" Name="LblDay" Style="{StaticResource SectionText}"/>
                            <ComboBox Name="CmbDay" Style="{StaticResource InputComboBox}"/>

                            <TextBlock Text="Тип питания" Name="LblMealType" Style="{StaticResource SectionText}"/>
                            <ComboBox Name="CmbMealType" Style="{StaticResource InputComboBox}"/>

                            <TextBlock Text="Рецепт" Name="LblMealRecipe" Style="{StaticResource SectionText}"/>
                            <ComboBox Name="CmbMealRecipe" Style="{StaticResource InputComboBox}"/>

                            <Button Name="BtnAddMeal"
                                    Content="Добавить в план"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnAddMeal_Click"/>

                            <Button Name="BtnGenerateAutoPlan"
                                    Content="Сгенерировать пример недели"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnGenerateAutoPlan_Click"/>

                            <Button Name="BtnClearMealPlan"
                                    Content="Очистить план"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnClearMealPlan_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Name="MealPlanListCard" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="План на неделю"
                                       Name="LblWeekPlan"
                                       Style="{StaticResource TitleText}"/>

                            <ListBox Grid.Row="1"
                                     Name="MealPlanList"
                                     Style="{StaticResource SoftList}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- SHOPPING -->
            <TabItem Header="🛒 Покупки">
                <Grid Name="ShoppingPanel" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Name="ShoppingFormCard" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Список покупок"
                                       Name="LblShoppingTitle"
                                       Style="{StaticResource TitleText}"/>

                            <TextBlock Text="Можно создать список для одного рецепта или для всего недельного плана."
                                       Name="LblShoppingHint"
                                       TextWrapping="Wrap"
                                       Opacity="0.75"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Рецепт" Name="LblSelectRecipe" Style="{StaticResource SectionText}"/>
                            <ComboBox Name="CmbRecipes" Style="{StaticResource InputComboBox}"/>

                            <Button Name="BtnCreateList"
                                    Content="Список для выбранного рецепта"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnCreateList_Click"/>

                            <Button Name="BtnCreatePlanShoppingList"
                                    Content="Список для недельного плана"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnCreatePlanShoppingList_Click"/>

                            <Button Name="BtnClearShoppingList"
                                    Content="Очистить список"
                                    Style="{StaticResource MainButton}"
                                    Click="BtnClearShoppingList_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Name="ShoppingResultCard" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Итоговый список"
                                       Name="LblShoppingResult"
                                       Style="{StaticResource TitleText}"/>

                            <ListBox Grid.Row="1"
                                     Name="ShoppingListBox"
                                     Style="{StaticResource SoftList}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- IMPORT -->
            <TabItem Header="🔌 Импорт">
                <Grid Name="ImportPanel" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="420"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Name="ImportJsonCard" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Импорт рецептов из JSON"
                                           Name="LblImportTitle"
                                           Style="{StaticResource TitleText}"/>
                                <TextBlock Text="Вставь JSON вручную или загрузи файл. Можно импортировать один рецепт или массив рецептов."
                                           Name="LblImportHint"
                                           TextWrapping="Wrap"
                                           Opacity="0.75"
                                           Margin="0,0,0,12"/>
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Name="TxtExternalRecipeJson"
                                     Style="{StaticResource InputTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>

                            <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                                <Button Name="BtnLoadJsonFile"
                                        Content="Выбрать файл"
                                        Style="{StaticResource MainButton}"
                                        Click="BtnLoadJsonFile_Click"/>

                                <Button Name="BtnImportExternalRecipe"
                                        Content="Импортировать"
                                        Style="{StaticResource MainButton}"
                                        Click="BtnImportExternalRecipe_Click"/>

                                <Button Name="BtnClearImport"
                                        Content="Очистить"
                                        Style="{StaticResource MainButton}"
                                        Click="BtnClearImport_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Name="ImportResultCard" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Результат импорта"
                                       Name="LblImportResult"
                                       Style="{StaticResource TitleText}"/>

                            <ListBox Grid.Row="1"
                                     Name="ImportResultList"
                                     Style="{StaticResource SoftList}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>