<Window x:Class="Cook_Plan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cook&amp;Plan" Height="300" Width="400"
        Name="RootWindow">
    <StackPanel Margin="20" VerticalAlignment="Center">

        <TextBlock Name="TitleText"
                   Text="Cook&amp;Plan"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Button Name="LightBtn"
                Content="☀️ Светлая тема"
                Margin="0,5"
                Padding="10,5"
                Click="LightBtn_Click"/>

        <Button Name="DarkBtn"
                Content="🌙 Тёмная тема"
                Margin="0,5"
                Padding="10,5"
                Click="DarkBtn_Click"/>

    </StackPanel>
</Window>